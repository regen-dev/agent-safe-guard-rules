{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://regen-dev.github.io/agent-safe-guard-rules/schemas/package-manifest.schema.json",
  "title": "agent-safe-guard package manifest",
  "type": "object",
  "required": ["package", "version", "rules"],
  "additionalProperties": true,
  "properties": {
    "package": {
      "type": "string",
      "pattern": "^[a-z0-9._-]+$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "package_version": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": ["rule_id", "name", "phase", "severity"],
      "additionalProperties": true,
      "properties": {
        "rule_id": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "enum": [
            "pre_tool_use",
            "post_tool_use",
            "permission_request",
            "read_compress",
            "read_guard",
            "stop",
            "session_start",
            "session_end",
            "pre_compact",
            "subagent_start",
            "subagent_stop",
            "tool_error"
          ]
        },
        "severity": {
          "type": "string",
          "enum": ["info", "low", "medium", "high", "critical"]
        }
      }
    }
  }
}
